{
  "manifest_version": 3,
  "name": "Gaetin Maps Scraper",
  "version": "1.0",
  "description": "Ekstrak leads langsung dari Google Maps ke Gaetin CRM.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://gaetin.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
