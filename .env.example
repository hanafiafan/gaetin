# ============================================================================
# KONFIGURASI ENVIRONMENT — Gaetin
#
# Legenda:
#   [WAJIB · GRATIS]      = harus diisi untuk menjalankan sistem; tanpa biaya
#   [WAJIB JIKA JUAL]     = wajib hanya kalau menerima pembayaran langganan
#   [OPSIONAL · GRATIS]   = boleh kosong; ada free tier
#   [OPSIONAL · BERBAYAR] = hanya jika butuh; menambah biaya — tunda di awal
#
# Prinsip: untuk MVP cukup isi blok [WAJIB · GRATIS] saja. Semuanya bisa
# berjalan dengan satu VPS tanpa langganan pihak ketiga.
# ============================================================================

# ---------- [WAJIB · GRATIS] DATABASE (self-host) ----------
DATABASE_URL="postgresql://postgres:password@localhost:5432/gaetin?schema=public"

# ---------- [WAJIB · GRATIS] REDIS / QUEUE (self-host) ----------
REDIS_URL="redis://localhost:6379"

# ---------- [WAJIB · GRATIS] AUTH (kamu generate sendiri) ----------
# Buat dengan: openssl rand -base64 48
JWT_SECRET="ganti-dengan-secret-acak-yang-panjang"
JWT_EXPIRES_IN="24h"

# ---------- [WAJIB · GRATIS] APP ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ---------- [OPSIONAL · GRATIS] DOMAIN ADMIN / CMS OWNER ----------
# Kosongkan saat development agar /admin tetap bisa dibuka lewat localhost.
# Saat produksi, isi agar admin/CMS hanya diarahkan lewat domain khusus.
# Contoh:
#   DOMAIN="gaetin.com"
#   ADMIN_DOMAIN="admin.gaetin.com"
#   ADMIN_HOSTS="admin.gaetin.com"
#   ADMIN_PRIMARY_URL="https://admin.gaetin.com"
#   ADMIN_ENTRY_PATH="/owner-console"
#   AUTH_COOKIE_DOMAIN=".gaetin.com"
DOMAIN="localhost"
ADMIN_DOMAIN="admin.localhost"
ADMIN_HOSTS=""
ADMIN_PRIMARY_URL=""
ADMIN_ENTRY_PATH=""
AUTH_COOKIE_DOMAIN=""

# ---------- [WAJIB · GRATIS] WHATSAPP (default: Baileys, tanpa API key) ----------
# baileys = gratis, koneksi via QR (default & direkomendasikan)
# gateway / cloud_api = opsional & berbayar (lihat blok di bawah)
WA_PROVIDER="baileys"
WA_SESSION_DIR="./wa-sessions"

# ---------- [OPSIONAL · GRATIS] PETA & GEOCODING ----------
# Tile peta: kosongkan untuk pakai free tier OSM/penyedia gratis.
# Geocoding default pakai Nominatim publik (gratis, di-cache) — tidak perlu key.
MAP_TILE_URL=""            # mis. URL template MapTiler/Stadia bila pakai free tier
GEOCODER_PROVIDER="nominatim"   # nominatim (gratis) | locationiq | google
# Scraper lead gratis default memakai Overpass/OpenStreetMap; tidak perlu API key.
OVERPASS_API_URL="https://overpass-api.de/api/interpreter"

# ---------- [WAJIB JIKA JUAL] BILLING — Xendit (per-transaksi) ----------
# Secret key dari dashboard Xendit (mode test gratis untuk development).
XENDIT_SECRET_KEY=""
# Token verifikasi webhook (Xendit > Settings > Webhooks > Verification Token).
XENDIT_WEBHOOK_TOKEN=""

# ---------- [OPSIONAL · GRATIS] EMAIL (free tier Resend/Brevo/SMTP) ----------
# Untuk invoice, reset password, notifikasi. Boleh kosong saat dev.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="no-reply@gaetin.example"

# ============================================================================
# OPSIONAL · BERBAYAR — JANGAN diisi di awal. Tambahkan hanya bila terbukti
# perlu, dan biayanya ditutup oleh paket langganan / pakai key milik tenant.
# ============================================================================

# ---------- [OPSIONAL · BERBAYAR] WHATSAPP gateway / API resmi ----------
WA_GATEWAY_BASE_URL=""
WA_GATEWAY_TOKEN=""
WA_CLOUD_API_TOKEN=""
WA_CLOUD_PHONE_NUMBER_ID=""

# ---------- [OPSIONAL · BERBAYAR] GEOCODER berbayar (akurasi/volume tinggi) ----------
GEOCODER_API_KEY=""

# ---------- [OPSIONAL · BERBAYAR] SCRAPER eksternal / self-host ----------
# Kosongkan untuk mode gratis Overpass. Isi hanya jika nanti memakai worker scraper internal.
SCRAPER_SERVICE_URL=""
# Tidak dipakai oleh mode gratis default.
SCRAPER_PROXY_URL=""

# ---------- [OPSIONAL · BERBAYAR] STORAGE S3 (kalau tak pakai disk VPS) ----------
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
